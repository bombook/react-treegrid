generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model project_task {
  id          Int      @id @default(autoincrement())
  workspace_id String?
  project_id  Int
  parent_id   Int?
  name        String
  start_date  DateTime
  end_date    DateTime
  progress    Int      @default(0)
  status      String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([project_id])
  @@index([parent_id])
}
